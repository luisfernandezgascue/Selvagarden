# Client-side (Vite — must be prefixed VITE_)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co   # optional — defaults to Selva project URL

# Server-side (Vercel serverless functions — no VITE_ prefix)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Loyverse POS integration
LOYVERSE_API_TOKEN=your_loyverse_api_token_here
