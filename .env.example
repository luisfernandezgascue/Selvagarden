# Client-side (Vite — must be prefixed VITE_)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co   # optional — defaults to Selva project URL

# Server-side (Vercel serverless functions — no VITE_ prefix)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Square POS integration — get these from developer.squareup.com
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_LOCATION_ID=your_square_location_id_here
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key_here
